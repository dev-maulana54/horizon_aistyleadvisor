database.default.hostname = localhost\SQLEXPRESS
database.default.database = db_fixmatchai
#kosongin username dan password jika di buka di laptop
database.default.username = sa
database.default.password = User@qa10
database.default.DBDriver = SQLSRV
database.default.DBPrefix =
database.default.port =

public string $protocol   = 'smtp';
public string $SMTPHost   = 'smtp.gmail.com';
public string $SMTPUser   = 'lanayeager12@gmail.com';
public string $SMTPPass   = '';   // harus App Password
public int    $SMTPPort   = 587;
public string $SMTPCrypto = 'tls';

public string $mailType   = 'html';
public string $charset    = 'UTF-8';
public string $newline    = "\r\n";
public string $CRLF       = "\r\n";
public bool   $SMTPAuth   = true;

